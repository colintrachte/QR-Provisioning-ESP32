{
    // ==========================================================
    // tractor_firmware/.vscode/settings.json
    //
    // NOTE: run "PlatformIO: Build" once before opening any .c
    // files. PlatformIO generates compile_commands.json during
    // build — clangd reads it to resolve all ESP-IDF types and
    // include paths. Until that file exists, clangd will show
    // false "unknown identifier" errors on ESP-IDF types.
    // ==========================================================

    // ── Format on save ────────────────────────────────────────
    "editor.formatOnSave":  true,
    "editor.formatOnPaste": true,
    "editor.formatOnType":  false,

    // ── clangd as the C/C++ engine ────────────────────────────
    // Disable the Microsoft IntelliSense engine — running both
    // simultaneously causes conflicts and duplicate errors.
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.formatting":         "disabled",

    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },

    // ── clangd configuration ──────────────────────────────────
    // compile_commands.json is generated by PlatformIO at:
    //   .pio/build/tractor_esp32/compile_commands.json
    // clangd reads it to know exactly how each file is compiled.
    "clangd.compilationDatabasePath": "${workspaceFolder}/.pio/build/tractor_esp32",
    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=never",
        "--log=error"
    ],

    // ── PlatformIO ────────────────────────────────────────────
    "platformio-ide.autoRebuildAutocompleteIndex": true,

    // ── Editor ────────────────────────────────────────────────
    "editor.tabSize":              4,
    "editor.insertSpaces":         true,
    "editor.detectIndentation":    false,
    "editor.rulers":               [100],
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline":    true,
    "files.eol":                   "\n",
    "files.associations": {
        "*.h": "c",
        "*.c": "c"
    },

    // ── Exclude build artifacts from Explorer + search ────────
    "files.exclude": {
        "**/.pio": true
    },
    "search.exclude": {
        "**/.pio": true
    }
}
