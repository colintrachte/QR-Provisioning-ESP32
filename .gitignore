Thumbs.db
desktop.ini

# --- VS Code (System Leak Protection) ---
# Ignore the entire folder first
.vscode/*
# Explicitly ignore files that contain local system paths
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
.vscode/*.log
# Allow specific team-shareable config[cite: 1]
!.vscode/extensions.json
!.vscode/arduino.json
!.vscode/settings.json

